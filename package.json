{
  "name": "tokenmaxxing-client",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "build:tests": "tsc -p tsconfig.test.json && cp -R test/fixtures dist/test/fixtures",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "report": "node dist/reporter/report.js",
    "install-service": "node dist/reporter/install.js",
    "uninstall-service": "node dist/reporter/uninstall.js",
    "test": "npm run build && npm run build:tests && node --test dist/test/*.test.js",
    "dev-report": "bash scripts/dev-report.sh",
    "prepare": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
