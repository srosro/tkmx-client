USERNAME=your-name
TEAM=your-team
API_KEY=your-api-key-from-registration
# CLIENT_ID is auto-generated on first run and appended to your .env. It pins
# usage data to a specific machine (PK on the server is username+date+model+client_id).
# DO NOT delete, overwrite, or hand-edit it — and if you re-clone the repo, copy
# your existing CLIENT_ID across. A new id looks like a new machine to the server,
# so the old id's rows linger and every overlapping (date, model) gets double-counted
# on your profile. If this happens, contact an admin to re-key the stale rows.
# CLIENT_ID=
# --- Tools, Projects & Communities ---
# Listing what you actually use day-to-day helps the developer community cut through
# the hype. Everyone's tweeting about the latest hot tool, but most of it is vaporware.
# Your real-world usage data shows what's actually being used in production.
#
# TOOLS      — What AI coding tools do you actually use daily? (e.g. superpowers,paperclip,cmux)
# PROJECTS   — What are you spending tokens on? (e.g. tkmx,plow.co)
# COMMUNITIES — What developer communities are you part of? (e.g. bloomberg-ai-engineering,agentcribs-community)
TOOLS=
PROJECTS=
COMMUNITIES=
# About — the main content of your profile page. This is your chance to share what
# you're building and how. Describe your AI coding setup, link to the tools you use,
# and share any content you've created about your workflow:
#   - Blog posts about your setup
#   - YouTube videos or tweets about your tools
#   - Links to the tools/plugins you're using (e.g. arsenal, superpowers)
#   - Your coding philosophy or approach
# URLs are auto-linked on your profile. Example:
# ABOUT="Building with https://github.com/nickarail/arsenal — here's my setup video: https://youtube.com/..."
ABOUT=
# Your Hacker News username (e.g. Sam_Odio). To appear on the leaderboard,
# add your tkmx profile URL to your HN about section. For example, see
# https://news.ycombinator.com/user?id=Sam_Odio — the about field links to
# https://tkmx.odio.dev/user/samodio. Then click "Verify" on your tkmx profile.
HN_USERNAME=
# Demo video (YouTube URL, 3 minutes or shorter) — embedded on your profile page
# under the "3-MIN DEMO VIDEO" heading. Keep it tight: the 3-minute cap is enforced
# socially, not technically, but longer videos get skipped. Show before/after
# workflows: what your process looked like before AI tools vs. after.
# Example: DEMO_VIDEO_URL=https://www.youtube.com/watch?v=dQw4w9WgXcQ
DEMO_VIDEO_URL=
# Number of days of history to report (default: 28). Set to 1 for steady-state after initial sync.
# REPORT_DAYS=1
# Timeout in milliseconds for each ccusage invocation (default: 180000 = 3 min).
# Bump this if you have a large ~/.claude/projects tree and see "ccusage ETIMEDOUT".
# CCUSAGE_TIMEOUT_MS=300000
# Report machine config (hostname, OS, CPU, memory, installed skills, codex version,
# MCP server names, hook events, CLAUDE.md size, shell/terminal/editor, git worktrees).
# This is static setup info — what tools you have installed, not how you use them.
# Shown on your profile so others can see what top devs actually run.
# We NEVER send prompts, responses, conversation history, file contents, or API keys.
REPORT_MACHINE_CONFIG=true
# Report dev stats — HOW you code, not just what you have installed.
# This is the behavioral data that teaches others how top devs spend 10B+ tokens/week:
#   - Workflow: tool-call frequencies (Bash/Read/Edit/Grep/Agent), session count, avg
#     session length, agent dispatch %, hour-of-day activity, cache reuse ratio
#   - Outcomes: git commits, LOC added/removed, files changed, active repos
#     (from `git log` in repos Claude touched — no repo names or file names sent)
#   - Codex: session count, avg tokens/session, avg session duration
#   - Cursor: AI code attribution (tab-complete vs composer vs human lines)
# Privacy: NO file paths, NO prompt content, NO tool arguments, NO repo names, NO code.
# Only tool names, aggregate counts, and environment strings leave your machine.
REPORT_DEV_STATS=true
# Aggregate Claude Code usage from additional machines without installing the
# client on each. Comma-separated list of directories; each must contain a
# `projects/` subdirectory of JSONL session files (i.e. the same layout as
# ~/.claude). Point this at a synced snapshot of a remote machine's ~/.claude
# and its usage will be collected alongside local usage on every report.
# Example: EXTRA_CLAUDE_CONFIGS=/path/to/synced-laptop,/path/to/synced-desktop
# EXTRA_CLAUDE_CONFIGS=
# OpenAI Admin API key (sk-admin-...) — enables collecting platform.openai.com
# usage via the /v1/organization/usage endpoint. Create at:
#   https://platform.openai.com/settings/organization/admin-keys
# This is a READ-only usage query; the key never appears in the usage report
# we send to the server. Leave unset to skip OpenAI platform collection.
# WARNING: If your Codex CLI is authenticated with an API key (not ChatGPT
# subscription auth), its usage already shows up in platform.openai.com usage
# and setting this will double-count those tokens. Only enable this if Codex
# is using ChatGPT auth or if you don't use Codex CLI.
# OPENAI_ADMIN_KEY=sk-admin-...
