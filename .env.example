USERNAME=your-name
TEAM=your-team
API_KEY=your-api-key-from-registration
# Comma-separated tools/skills you actively use (only list what you actually use daily)
# Examples: superpowers,paperclip,cmux
TOOLS=
# Comma-separated communities you want shown as tags on your profile and leaderboard.
# Example: bloomberg-ai-engineering,agentcribs-community
COMMUNITIES=
# Comma-separated projects you're working on, shown on your profile.
# Example: tkmx,plow.co
PROJECTS=
# About — shown on your profile. Share your setup, workflow, and links to any posts/videos
# where you've discussed your config (blog posts, tweets, etc). URLs are auto-linked.
ABOUT=
# Number of days of history to report (default: 28). Set to 1 for steady-state after initial sync.
# REPORT_DAYS=1
# Report machine config (hostname, OS, CPU, memory, installed skills, codex version).
# This is shown on your profile page so others can see your setup.
# We NEVER send prompts, responses, conversation history, file contents, or API keys.
REPORT_MACHINE_CONFIG=true
